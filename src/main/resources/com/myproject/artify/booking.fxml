<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.myproject.artify.BookingController"
            prefWidth="800" prefHeight="600"
            style="-fx-background-color: linear-gradient(to bottom right, #ffe6f0, #ffd9e8);">

    <!-- HEADER -->
    <top>
        <VBox alignment="CENTER" spacing="5"
              style="-fx-background-color: #ffb6c1; -fx-padding: 20;">
            <Label text="📅 Book Workshop"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;" />
            <Label text="Choose your session and additional options"
                   style="-fx-font-size: 14px; -fx-text-fill: #ffe6f2;" />
        </VBox>
    </top>

    <!-- SCROLLABLE CENTER CONTENT -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent;"
                    hbarPolicy="NEVER">
            <content>
                <VBox alignment="CENTER" spacing="20" style="-fx-padding: 40;">

                    <VBox spacing="15" alignment="CENTER_LEFT"
                          maxWidth="450"
                          style="-fx-background-color: white; -fx-padding: 30;
                                 -fx-border-color: #ff9aae; -fx-border-radius: 10;
                                 -fx-background-radius: 10;
                                 -fx-effect: dropshadow(gaussian, #f8c2d1, 8, 0.5, 0, 2);">

                        <!-- Workshop Info -->
                        <Label fx:id="lblWorkshopTitle"
                               text="Workshop Title"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #d6336c;" />

                        <Label fx:id="lblBaseFee"
                               text="Base Fee: RM 0.00"
                               style="-fx-font-size: 14px; -fx-text-fill: #a05278;" />

                        <!-- Session Selection -->
                        <Label text="🕒 Select Session:"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #d6336c;" />

                        <HBox spacing="20">
                            <RadioButton fx:id="rbMorning" text="Morning Session"
                                         style="-fx-text-fill: #7a4b61;" />
                            <RadioButton fx:id="rbAfternoon" text="Afternoon Session"
                                         style="-fx-text-fill: #7a4b61;" />
                        </HBox>

                        <!-- Extras -->
                        <Label text="➕ Additional Options:"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #d6336c;" />

                        <VBox spacing="10">
                            <CheckBox fx:id="chkMaterials"
                                      text="Include Materials (+RM20)"
                                      style="-fx-text-fill: #7a4b61;" />
                            <CheckBox fx:id="chkCertificate"
                                      text="Certificate (+RM10)"
                                      style="-fx-text-fill: #7a4b61;" />
                        </VBox>

                        <!-- Total -->
                        <Label text="Total Price:"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #d6336c;" />

                        <TextField fx:id="txtTotal" editable="false" prefWidth="200"
                                   style="-fx-background-color: #ffe6f2;
                                          -fx-border-color: #ff9aae;
                                          -fx-text-fill: #7a004c;" />

                        <!-- Confirm Button -->
                        <Button fx:id="btnConfirm"
                                text="Confirm Booking"
                                onAction="#handleConfirm"
                                style="-fx-background-color: #ff9aae;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 8;
                                       -fx-pref-width: 300;
                                       -fx-pref-height: 35;
                                       -fx-cursor: hand;" />
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

    <!-- BOTTOM NAVIGATION -->
    <bottom>
        <HBox alignment="CENTER" spacing="10"
              style="-fx-padding: 15; -fx-background-color: #ffb6c1;">
            <Button fx:id="btnCancel"
                    text="← Back to Menu"
                    onAction="#handleCancel"
                    style="-fx-background-color: white;
                           -fx-text-fill: #d6336c;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-border-color: #ff9aae;
                           -fx-border-width: 1.5;
                           -fx-cursor: hand;" />
        </HBox>
    </bottom>

</BorderPane>
