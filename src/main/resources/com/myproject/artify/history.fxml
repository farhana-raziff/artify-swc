<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.myproject.artify.HistoryController"
            prefWidth="800" prefHeight="500"
            style="-fx-background-color: linear-gradient(to bottom right, #ffe6f0, #ffd9e8);">

    <!-- HEADER -->
    <top>
        <VBox alignment="CENTER" spacing="5"
              style="-fx-background-color: #ffb6c1; -fx-padding: 15;">
            <Label text="🧾 Booking History"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" />
            <Label text="See all workshops you have booked."
                   style="-fx-font-size: 13px; -fx-text-fill: #ffe6f2;" />
        </VBox>
    </top>

    <!-- CENTER -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent;">
            <VBox alignment="CENTER" spacing="20" style="-fx-padding: 20;">

                <!-- SEARCH BAR -->
                <HBox alignment="CENTER">
                    <TextField fx:id="txtSearch"
                               promptText="Search by workshop name, date, session..."
                               style="-fx-background-radius: 20;
                                      -fx-border-radius: 20;
                                      -fx-padding: 8 15;
                                      -fx-pref-width: 400;" />
                </HBox>

                <!-- TABLE -->
                <TableView fx:id="tblBookings"
                           prefWidth="700" prefHeight="300"
                           style="-fx-background-color: white;
                                  -fx-border-color: #ff9aae;
                                  -fx-border-radius: 10;
                                  -fx-background-radius: 10;
                                  -fx-effect: dropshadow(gaussian, #f8c2d1, 8, 0.5, 0, 2);">

                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colWorkshopTitle" text="Workshop" prefWidth="150"/>
                        <TableColumn fx:id="colSession" text="Session" prefWidth="120"/>
                        <TableColumn fx:id="colMaterials" text="Extras" prefWidth="120"/>
                        <TableColumn fx:id="colTotal" text="Total (RM)" prefWidth="100"/>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="130"/>
                        <TableColumn fx:id="colDelete" text="Delete" prefWidth="80"/>
                    </columns>
                </TableView>

                <Label fx:id="lblInfo"
                       text="Showing your latest bookings."
                       style="-fx-font-size: 13px; -fx-text-fill: #d6336c;" />
            </VBox>
        </ScrollPane>
    </center>

    <!-- BACK BUTTON -->
    <bottom>
        <HBox alignment="CENTER" spacing="10"
              style="-fx-padding: 10; -fx-background-color: #ffb6c1;">
            <Button text="← Back to Menu" onAction="#handleBack"
                    style="-fx-background-color: white;
                           -fx-text-fill: #d6336c;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-border-color: #ff9aae;
                           -fx-border-width: 1.5;
                           -fx-cursor: hand;" />
        </HBox>
    </bottom>

</BorderPane>
