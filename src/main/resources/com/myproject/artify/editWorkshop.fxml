<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.myproject.artify.EditWorkshopController"
            prefWidth="800" prefHeight="500"
            style="-fx-background-color: linear-gradient(to bottom right, #ffe6f0, #ffd9e8);">

    <!-- HEADER -->
    <top>
        <VBox alignment="CENTER" spacing="5"
              style="-fx-background-color: #ffb6c1; -fx-padding: 20;">
            <Label text="📝 Edit Workshop"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;" />
            <Label text="Update the workshop details below."
                   style="-fx-font-size: 14px; -fx-text-fill: #ffe6f2;" />
        </VBox>
    </top>

    <!-- SCROLLABLE CENTER -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent;"
                    vbarPolicy="ALWAYS">
            <content>
                <VBox alignment="CENTER" spacing="20" style="-fx-padding: 30;">

                    <VBox spacing="12" maxWidth="420"
                          style="-fx-background-color: white;
                                 -fx-border-color: #ff9aae;
                                 -fx-border-radius: 10;
                                 -fx-background-radius: 10;
                                 -fx-padding: 25;
                                 -fx-effect: dropshadow(gaussian,#f8c2d1,8,0.5,0,2);">

                        <Label text="Workshop Title:" />
                        <TextField fx:id="txtTitle" />

                        <Label text="Description:" />
                        <TextArea fx:id="txtDescription"
                                  prefRowCount="4"
                                  wrapText="true"
                                  style="-fx-background-radius: 6;" />

                        <Label text="Date / Schedule:" />
                        <TextField fx:id="txtDate" />

                        <Label text="Time:" />
                        <TextField fx:id="txtTime" />

                        <Label text="Fee (RM):" />
                        <TextField fx:id="txtFee" />

                        <Label fx:id="lblMessage"
                               style="-fx-text-fill: #d6336c; -fx-font-size: 12px;" />
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

    <!-- FOOTER BUTTONS -->
    <bottom>
        <HBox alignment="CENTER" spacing="10"
              style="-fx-padding: 15; -fx-background-color: #ffb6c1;">

            <Button text="Save Changes"
                    onAction="#handleUpdate"
                    style="-fx-background-color: white;
                           -fx-text-fill: #d6336c;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-border-color: #ff9aae;
                           -fx-border-width: 1.5;" />

            <Button text="← Back"
                    onAction="#handleBack"
                    style="-fx-background-color: #ffc0cb;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;" />
        </HBox>
    </bottom>

</BorderPane>
